rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ──────────────────────────────────────────────────
    // Any authenticated user can READ any user doc (needed for friends/social features)
    // Only the owner can WRITE their own document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Subcollections: any auth user can read, only owner can write
      match /{subcollection}/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Public profiles (social features) ─────────────────────────────────
    // Any logged-in user can read public profiles (for friend search)
    // Only the owner can write their own public profile
    match /publicProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Friend connections ─────────────────────────────────────────────────
    match /friends/{connectionId} {
      allow read: if request.auth != null &&
        (resource.data.user1 == request.auth.uid ||
         resource.data.user2 == request.auth.uid);
      allow create: if request.auth != null &&
        request.resource.data.user1 == request.auth.uid;
      allow update, delete: if request.auth != null &&
        (resource.data.user1 == request.auth.uid ||
         resource.data.user2 == request.auth.uid);
    }

    // ── Deny all other access ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
